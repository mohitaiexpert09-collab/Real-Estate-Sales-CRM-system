# ─────────────────────────────────────────────────────────────
#  PropPulse CRM — copy this file to ".env" and fill in your keys
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (works on Vercel AND locally).
# Get a free one from Neon (neon.tech) or Vercel Storage → Postgres,
# then paste the connection string here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── AI provider ──────────────────────────────────────────────
# The app auto-picks: OpenAI key wins, then Anthropic, else a
# built-in demo AI (so it runs fully offline with no keys at all).
# Force one with LLM_PROVIDER if you like.
# LLM_PROVIDER="openai"        # or "anthropic"

# ── OpenAI (recommended) ─────────────────────────────────────
OPENAI_API_KEY="sk-REPLACE_WITH_YOUR_OPENAI_KEY"
OPENAI_MODEL="gpt-4o-mini"

# ── Anthropic / Claude (optional) ────────────────────────────
# ANTHROPIC_API_KEY="sk-ant-REPLACE_WITH_YOUR_KEY"
AGENT_MODEL="claude-haiku-4-5"
